# ── Base de datos ────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=cambia_esto_root
DB_NAME=cartilladigitalinga
DB_USER=inga_user
DB_PASSWORD=cambia_esto_password

# ── Auth ─────────────────────────────────────────────────────────────────────
# Genera uno seguro: openssl rand -hex 64
JWT_SECRET=cambia_esto_jwt_secret_muy_largo

# Google OAuth (mismo client ID del proyecto en Google Cloud Console)
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Las credenciales de Cloudinary se configuran desde el panel Admin de la app
# (tabla `configuracion` en la BD), no son variables de entorno del servidor.

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dominio público del frontend — separa múltiples con coma
ALLOWED_ORIGINS=https://tudominio.com
